{
  "name": "tikr",
  "version": "0.0.1",
  "description": "A beautiful Pomodoro & countdown timer, right in your terminal",
  "type": "module",
  "bin": {
    "tikr": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "start": "node dist/index.js",
    "link": "pnpm link --global",
    "prepublishOnly": "pnpm test && pnpm build",
    "publish:npm": "pnpm run prepublishOnly && pnpm publish",
    "publish:npm:dry-run": "pnpm run prepublishOnly && pnpm publish --dry-run",
    "release:major": "node scripts/release.mjs major",
    "release:minor": "node scripts/release.mjs minor",
    "release:patch": "node scripts/release.mjs patch",
    "unlink": "pnpm unlink --global"
  },
  "author": "Ashar Irfan",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asharirfan/tikr.git"
  },
  "homepage": "https://github.com/asharirfan/tikr#readme",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "figlet": "^1.8.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "node-notifier": "^10.0.1",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^18.3.1",
    "prettier": "^3.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-notifier"
    ]
  }
}
